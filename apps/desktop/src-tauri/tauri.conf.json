{
  "$schema": "https://raw.githubusercontent.com/nicholasgasior/tauri/tauri-v2.0.0/crates/tauri-utils/schema.json",
  "productName": "Talkiwi",
  "version": "0.1.0",
  "identifier": "com.talkiwi.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "ball",
        "url": "ball.html",
        "title": "Talkiwi",
        "width": 40,
        "height": 40,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "acceptFirstMouse": true,
        "focus": true
      },
      {
        "label": "editor",
        "url": "index.html",
        "title": "Talkiwi Editor",
        "width": 720,
        "height": 600,
        "minWidth": 500,
        "minHeight": 400,
        "decorations": true,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
